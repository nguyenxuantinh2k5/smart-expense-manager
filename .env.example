# Cau hinh Django
SECRET_KEY=django-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Cau hinh database
# Hien tai settings.py co the dang dung block DATABASES hardcode.
# Cac bien duoi day dung khi ban bat lai block DATABASES doc tu .env
# trong core/settings.py.
DB_ENGINE=django.db.backends.postgresql
DB_NAME=smart_expense_db
DB_USER=postgres
DB_PASSWORD=admin123
DB_HOST=127.0.0.1
DB_PORT=5432

# Cau hinh Gemini API
# Co the de trong neu chi muon dung local parser cho nhap chu.
# Phan tich anh hoa don can GEMINI_API_KEY hop le.
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-flash-lite-latest
GEMINI_IMAGE_MODEL_IDS=gemini-flash-lite-latest,gemini-2.0-flash-lite,gemini-2.5-flash

# Cach xu ly AI khi nhap chu
# fallback: uu tien local parser, chi goi Gemini khi local chua du du lieu
# local: khong bao gio goi Gemini cho nhap chu
# always: luon goi Gemini cho nhap chu
EXPENSE_TEXT_AI_MODE=fallback
GEMINI_TEXT_MAX_RETRIES=1
GEMINI_IMAGE_MAX_RETRIES=2
GEMINI_RETRY_DELAY_SECONDS=2
